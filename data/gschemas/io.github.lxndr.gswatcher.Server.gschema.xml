<?xml-model href="/usr/share/glib-2.0/schemas/gschema.dtd"?>

<schemalist>
  <schema id="io.github.lxndr.gswatcher.Server">
    <key name="server-name" type="s">
      <default>""</default>
      <summary>Server name</summary>
    </key>
    <key name="protocol-id" type="s">
      <default>""</default>
      <summary>Protocol</summary>
    </key>
    <key name="game-id" type="s">
      <default>""</default>
      <summary>Game ID</summary>
    </key>
    <key name="console-port" type="q">
      <range min="1024" max="49151" />
      <default>1024</default>
      <summary>Remote console port</summary>
    </key>
    <key name="console-password" type="s">
      <default>""</default>
      <summary>Remote console password</summary>
    </key>
    <key name="console-command-history" type="as">
      <default>[]</default>
      <summary>Remote console command history</summary>
    </key>
    <key name="notify-server-online" type="b">
      <default>true</default>
      <summary>Notify when server goes online</summary>
    </key>
    <key name="notify-server-offline" type="b">
      <default>true</default>
      <summary>Notify when server goes offline</summary>
    </key>
    <key name="notify-player-slot-available" type="b">
      <default>true</default>
      <summary>Notify when player slot is available</summary>
    </key>
  </schema>
</schemalist>
